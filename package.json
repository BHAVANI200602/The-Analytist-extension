{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "scapegoat",
  "displayName": "Scapegoat",
  "description": "Broke AI Assistant that fixes errors and analyzes files in your workspace ",
  "version": "1.0.1",
  "icon": "logo.png",
  "publisher": "Bhavani-200602",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/BHAVANI200602/Scapegoat-extension.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "AI",
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onCommand:scapegoat.openChat",
    "onCommand:scapegoat.analyzeError"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "scapegoat.openChat",
        "title": "Scapegoat: Open AI Assistant"
      },
      {
        "command": "scapegoat.analyzeError",
        "title": "Scapegoat: Analyze Error"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "scapegoat.analyzeError",
          "when": "editorHasSelection",
          "group": "navigation"
        },
        {
          "command": "scapegoat.openChat",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Scapegoat",
      "properties": {
        "scapegoat.defaultProvider": {
          "type": "string",
          "default": "gemini",
          "enum": [
            "openai",
            "gemini",
            "anthropic",
            "openrouter",
            "custom"
          ],
          "description": "Default AI service provider."
        },
        "scapegoat.defaultModel": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "Default model name to use."
        },
        "scapegoat.customEndpoint": {
          "type": "string",
          "default": "http://localhost:11434/v1",
          "description": "Base URL for the Custom OpenAI-compatible provider (e.g. Ollama, LM Studio)."
        },
        "scapegoat.enableTokenOptimization": {
          "type": "boolean",
          "default": true,
          "description": "Automatically minimize token usage via sliding windows and comment stripping."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile:extension": "esbuild src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node",
    "compile:webview": "npm run build --prefix webview-ui",
    "compile": "npm run compile:extension && npm run compile:webview"
  },
  "devDependencies": {
    "@types/node": "^18.11.18",
    "@types/node-fetch": "^2.6.12",
    "@types/vscode": "^1.74.0",
    "esbuild": "^0.25.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "node-fetch": "^2.6.7"
  }
}
